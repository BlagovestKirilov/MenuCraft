<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" packages="co.elastic.logging.log4j2">

    <Properties>
        <Property name="LOG_DIR">logs</Property>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
    </Properties>

    <Appenders>
        <!-- Console appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}" />
        </Console>

        <!-- ECS JSON file appender for Elastic Observability -->
        <RollingFile name="EcsFile"
                     fileName="${LOG_DIR}/menucraft-ecs.json"
                     filePattern="${LOG_DIR}/menucraft-ecs-%d{yyyy-MM-dd}.json.gz">
            <EcsLayout serviceName="MenuCraft" />
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true" />
            </Policies>
            <DefaultRolloverStrategy>
                <Delete basePath="${LOG_DIR}" maxDepth="1">
                    <IfFileName glob="menucraft-ecs-*.json.gz" />
                    <IfLastModified age="7d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- Rolling file appender: daily rotation, keep 7 days -->
        <RollingFile name="RollingFile"
                     fileName="${LOG_DIR}/menucraft.log"
                     filePattern="${LOG_DIR}/menucraft-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}" />
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true" />
            </Policies>
            <DefaultRolloverStrategy>
                <Delete basePath="${LOG_DIR}" maxDepth="1">
                    <IfFileName glob="menucraft-*.log.gz" />
                    <IfLastModified age="7d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Application logger -->
        <Logger name="bg.menucraft" level="INFO" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
            <AppenderRef ref="EcsFile" />
        </Logger>

        <!-- Hibernate SQL -->
        <Logger name="org.hibernate.SQL" level="INFO" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
            <AppenderRef ref="EcsFile" />
        </Logger>

        <!-- Spring framework -->
        <Logger name="org.springframework" level="WARN" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
            <AppenderRef ref="EcsFile" />
        </Logger>

        <Root level="WARN">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
            <AppenderRef ref="EcsFile" />
        </Root>
    </Loggers>

</Configuration>
